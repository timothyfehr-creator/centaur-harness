# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Secrets / local config (never commit)
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.keystore
id_rsa
id_ed25519
credentials.json
secrets.*
.aws/
.ssh/

# WP-A1b live lane: the run-local spend ledger + any live RAW wire bytes (which carry model prose; the real
# raw-wire dir lives OUTSIDE the repo tree, this is belt-and-suspenders). COMMITTED response bytes are REDACTED.
*.local.json
run/**/*.local.json
live_raw/
**/live_raw/

# Test fixtures intentionally contain fake key-/secret-shaped files; keep them
# tracked despite the secret patterns above.
!tests/fixtures/**

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# AI-tooling working dirs (agent sessions, worktrees) — not part of the repo
.claude/*
# ...EXCEPT the committed, version-controlled security guardrail (transparent by design):
# a PreToolUse deny-hook that blocks AI tool calls from editing the attestation files
# or pushing/merging to main. See .claude/hooks/security-deny.py.
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/**
